{
    "framework": null,
    "buildCommand": "",
    "outputDirectory": ".",
    "rewrites": [
        { "source": "/api/dart", "destination": "/api/dart" }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Frame-Options", "value": "DENY" }
            ]
        }
    ]
}
